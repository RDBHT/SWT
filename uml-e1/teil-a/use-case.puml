@startuml IT-Service-Monitor-UseCase
skinparam dpi 200
left to right direction
skinparam packageStyle rectangle

actor Operator
actor Admin
Admin --|> Operator

rectangle "IT-Service-Monitor" {
  usecase "Service-Status einsehen" as UC1
  usecase "Alert quittieren" as UC2
  usecase "Service anlegen" as UC3
  usecase "Check konfigurieren" as UC4
  usecase "Alert-Regel verwalten" as UC5
}

Operator --> UC1
Operator --> UC2
Admin --> UC3
Admin --> UC4
Admin --> UC5
UC3 ..> UC4 : <<include>>
@enduml
